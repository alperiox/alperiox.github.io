---
---

<canvas id="bg-canvas" aria-hidden="true"></canvas>

<style>
  #bg-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: block;
  }
</style>

<script>
  import Delaunator from 'delaunator';

  function initCanvasBackground() {
    const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.innerWidth < 768;

    const N_NODES = isMobile ? 55 : 110;
    const N_PARTICLES = isMobile ? 180 : 380;

    let W = 0, H = 0;

    interface MeshNode {
      bx: number; by: number;
      phase: number;
      freqX: number; freqY: number;
      ampX: number; ampY: number;
      x: number; y: number;
    }

    interface Particle {
      x: number; y: number;
      age: number; maxAge: number;
      speed: number; hueOff: number;
    }

    let nodes: MeshNode[] = [];
    const coords = new Float64Array(N_NODES * 2);

    function getHue(): number {
      return parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--hue')) || 270;
    }

    function isDarkMode(): boolean {
      return document.documentElement.classList.contains('dark');
    }

    function resize() {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
      initNodes();
    }

    function initNodes() {
      nodes = Array.from({ length: N_NODES }, () => ({
        bx: (Math.random() * 1.14 - 0.07) * W,
        by: (Math.random() * 1.14 - 0.07) * H,
        phase: Math.random() * Math.PI * 2,
        freqX: 0.16 + Math.random() * 0.22,
        freqY: 0.13 + Math.random() * 0.20,
        ampX: 10 + Math.random() * 24,
        ampY: 8 + Math.random() * 18,
        x: 0, y: 0,
      }));
    }

    function field(x: number, y: number, t: number): number {
      const nx = x / W, ny = y / H;
      return (
        Math.sin(nx * 3.2 + t * 0.35) * Math.cos(ny * 2.6 - t * 0.28) +
        Math.sin(nx * 1.1 - ny * 1.9 + t * 0.22)
      ) * Math.PI;
    }

    function makeParticle(randomAge: boolean): Particle {
      return {
        x: Math.random() * (W || 680),
        y: Math.random() * (H || 420),
        age: randomAge ? Math.random() * 100 : 0,
        maxAge: 70 + Math.random() * 100,
        speed: 0.45 + Math.random() * 0.95,
        hueOff: (Math.random() - 0.5) * 32,
      };
    }

    const particles: Particle[] = Array.from({ length: N_PARTICLES }, () => makeParticle(true));

    let t = 0;
    let animId = 0;
    let running = false;

    function draw() {
      if (!running) return;

      // In light mode, clear canvas and keep looping (invisible)
      if (!isDarkMode()) {
        ctx.clearRect(0, 0, W, H);
        animId = requestAnimationFrame(draw);
        return;
      }

      const hue = getHue();
      t += 0.007;

      // Update node positions + coords array
      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        n.x = n.bx + Math.sin(t * n.freqX + n.phase) * n.ampX;
        n.y = n.by + Math.cos(t * n.freqY + n.phase + 1.1) * n.ampY;
        coords[i * 2] = n.x;
        coords[i * 2 + 1] = n.y;
      }

      // Delaunay triangulation
      const del = new Delaunator(coords);
      const tri = del.triangles;

      // Background — palette-tinted near-black
      ctx.fillStyle = `hsl(${hue}, 30%, 3.5%)`;
      ctx.fillRect(0, 0, W, H);

      // Triangle fills
      for (let i = 0; i < tri.length; i += 3) {
        const a = nodes[tri[i]], b = nodes[tri[i + 1]], c = nodes[tri[i + 2]];
        const cx = (a.x + b.x + c.x) / 3;
        const cy = (a.y + b.y + c.y) / 3;
        const h = hue - 8 + (cx / W) * 32;
        const lum = 5.5 + (cy / H) * 5;
        ctx.beginPath();
        ctx.moveTo(a.x, a.y);
        ctx.lineTo(b.x, b.y);
        ctx.lineTo(c.x, c.y);
        ctx.closePath();
        ctx.fillStyle = `hsla(${h}, 52%, ${lum}%, 1)`;
        ctx.fill();
      }

      // Edges
      const drawn = new Set<string>();
      for (let i = 0; i < tri.length; i += 3) {
        const pairs: [number, number][] = [
          [tri[i], tri[i + 1]],
          [tri[i + 1], tri[i + 2]],
          [tri[i + 2], tri[i]],
        ];
        for (const [ai, bi] of pairs) {
          const key = ai < bi ? `${ai}-${bi}` : `${bi}-${ai}`;
          if (drawn.has(key)) continue;
          drawn.add(key);
          const a = nodes[ai], b = nodes[bi];
          const h = hue + ((a.x + b.x) / 2 / W) * 26;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = `hsla(${h}, 58%, 62%, 0.12)`;
          ctx.lineWidth = 0.6;
          ctx.stroke();
        }
      }

      // Node dots
      for (const n of nodes) {
        if (n.x < -20 || n.x > W + 20 || n.y < -20 || n.y > H + 20) continue;
        const h = hue + (n.x / W) * 30;
        ctx.beginPath();
        ctx.arc(n.x, n.y, 1.3, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(${h}, 68%, 72%, 0.20)`;
        ctx.fill();
      }

      // Particle trail fade
      ctx.fillStyle = `hsla(${hue}, 30%, 3.5%, 0.20)`;
      ctx.fillRect(0, 0, W, H);

      // Particles
      for (const p of particles) {
        const angle = field(p.x, p.y, t);
        const nx = p.x + Math.cos(angle) * p.speed;
        const ny = p.y + Math.sin(angle) * p.speed;
        const life = 1 - p.age / p.maxAge;
        const alpha = Math.sin(life * Math.PI) * 0.58;
        const h = hue + p.hueOff + Math.sin(p.x / W * 3 + t * 0.4) * 18;
        const lum = 68 + Math.sin(p.y / H * 2) * 12;
        ctx.beginPath();
        ctx.moveTo(p.x, p.y);
        ctx.lineTo(nx, ny);
        ctx.strokeStyle = `hsla(${h}, 64%, ${lum}%, ${alpha})`;
        ctx.lineWidth = 0.65;
        ctx.stroke();
        p.x = nx;
        p.y = ny;
        p.age++;
        if (p.age > p.maxAge || p.x < 0 || p.x > W || p.y < 0 || p.y > H) {
          Object.assign(p, makeParticle(false));
          p.x = Math.random() * W;
          p.y = Math.random() * H;
        }
      }

      animId = requestAnimationFrame(draw);
    }

    function start() {
      if (running) return;
      running = true;
      animId = requestAnimationFrame(draw);
    }

    function stop() {
      running = false;
      cancelAnimationFrame(animId);
    }

    // Pause when tab is hidden (save battery)
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        stop();
      } else if (!prefersReducedMotion) {
        start();
      }
    });

    window.addEventListener('resize', resize);
    resize();

    if (prefersReducedMotion) {
      // Single static frame
      running = true;
      draw();
      running = false;
    } else {
      start();
    }
  }

  initCanvasBackground();
</script>
